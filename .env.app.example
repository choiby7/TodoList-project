# ================================
# 앱 서버 환경 변수 템플릿
# ================================
# 사용법: 이 파일을 .env.app로 복사하고 실제 값으로 변경하세요
# cp .env.app.example .env.app

# ================================
# Database Configuration (연결용)
# ================================
# DB 서버 호스트 (프로덕션: DB 서버 IP, 로컬: localhost)
DB_HOST=localhost
DB_USERNAME=your_db_username
DB_PASSWORD=your_strong_password_here

# ================================
# Redis Configuration
# ================================
REDIS_PASSWORD=your_redis_password_here

# ================================
# JWT Configuration
# ================================
# JWT Secret Key (최소 256bit / 32자 이상 권장)
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long

# JWT Access Token 유효기간 (밀리초, 기본: 1시간 = 3600000)
JWT_ACCESS_EXPIRATION=3600000

# JWT Refresh Token 유효기간 (밀리초, 기본: 7일 = 604800000)
JWT_REFRESH_EXPIRATION=604800000

# ================================
# Google OAuth2 Configuration
# ================================
# Google Cloud Console에서 발급받은 클라이언트 ID
GOOGLE_CLIENT_ID=your_google_client_id_here

# Google Cloud Console에서 발급받은 클라이언트 시크릿
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ================================
# Application Configuration
# ================================
# Spring Boot 프로파일
SPRING_PROFILES_ACTIVE=prod

# 프론트엔드 URL (CORS 및 OAuth2 리다이렉트용)
# 로컬 환경: http://localhost
# 프로덕션 환경: https://cbytodolist.duckdns.org
FRONTEND_URL=https://cbytodolist.duckdns.org
