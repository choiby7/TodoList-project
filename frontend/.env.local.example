# ================================
# Frontend Environment Variables (Local Development)
# ================================

# API Base URL
# 로컬 개발 환경에서는 Backend가 localhost:8080에서 실행됨
NEXT_PUBLIC_API_URL=http://localhost:8080

# API Timeout (밀리초)
NEXT_PUBLIC_API_TIMEOUT=10000

# ================================
# 사용 방법
# ================================
# 1. 이 파일을 .env.local로 복사:
#    cp .env.local.example .env.local
#
# 2. 로컬 개발 시작:
#    npm run dev
#
# ================================
# Docker 환경
# ================================
# Docker Compose 환경에서는 docker-compose.yml에서
# NEXT_PUBLIC_API_URL=/api 로 설정됨 (Nginx가 프록시)
