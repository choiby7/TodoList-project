# ================================
# 앱 서버 환경 변수 템플릿 (프로덕션)
# ================================
# 사용법: 프로덕션 서버에서 이 파일을 .env.app로 복사하고 실제 값으로 변경하세요
# cp .env.app.prod.example .env.app

# ================================
# Database Configuration (연결용)
# ================================
# DB 서버 IP 주소 (예: 168.107.29.127)
DB_USERNAME=your_db_username
DB_PASSWORD=your_strong_password_here

# ================================
# Redis Configuration
# ================================
REDIS_PASSWORD=your_redis_password_here

# ================================
# JWT Configuration
# ================================
# JWT Secret Key (최소 256bit / 32자 이상 권장)
# 프로덕션 환경에서는 반드시 강력한 랜덤 키 사용
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long_production

# JWT Access Token 유효기간 (밀리초, 기본: 1시간 = 3600000)
JWT_ACCESS_EXPIRATION=3600000

# JWT Refresh Token 유효기간 (밀리초, 기본: 7일 = 604800000)
JWT_REFRESH_EXPIRATION=604800000

# ================================
# Google OAuth2 Configuration
# ================================
# Google Cloud Console에서 발급받은 클라이언트 ID
GOOGLE_CLIENT_ID=your_google_client_id_here

# Google Cloud Console에서 발급받은 클라이언트 시크릿
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ================================
# Application Configuration
# ================================
# Spring Boot 프로파일 (프로덕션)
SPRING_PROFILES_ACTIVE=prod

# 프론트엔드 URL (CORS 및 OAuth2 리다이렉트용)
# 프로덕션 도메인으로 변경하세요
FRONTEND_URL=http://cbytodolist.duckdns.org
