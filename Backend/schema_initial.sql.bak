CREATE TRIGGER tg_todos_completed_at BEFORE UPDATE ON todolist_db.todos FOR EACH ROW WHEN (((old.status)::text IS DISTINCT FROM (new.status)::text)) EXECUTE FUNCTION todolist_db.update_completed_at();


