--

CREATE TRIGGER tg_todos_deleted_at BEFORE UPDATE ON todolist_db.todos FOR EACH ROW WHEN ((old.is_deleted IS DISTINCT FROM new.is_deleted)) EXECUTE FUNCTION todolist_db.update_deleted_at();


